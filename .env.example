# ─────────────────────────────────────
# LLM Providers (at least one required)
# ─────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gpt-4.1-mini

# ─────────────────────────────────────
# Vector Store (Pinecone)
# ─────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=knowledge-base

# ─────────────────────────────────────
# PostgreSQL Database
# ─────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=nexus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Or provide a full connection string instead:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname

# ─────────────────────────────────────
# Redis (Job Queue, OAuth Store, WS Pub/Sub)
# ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────
# Authentication
# ─────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─────────────────────────────────────
# CORS (comma-separated frontend origins)
# ─────────────────────────────────────
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─────────────────────────────────────
# Google SSO (optional)
# ─────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────
# S3 / MinIO (Document Backup)
# ─────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=ap-south-1
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=nexus-knowledge-base

# ─────────────────────────────────────
# Document Encryption (optional)
# ─────────────────────────────────────
DOCUMENT_ENCRYPTION_KEY=

# ─────────────────────────────────────
# Connectors — Google Drive (optional)
# ─────────────────────────────────────
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/api/connectors/google/callback

# ─────────────────────────────────────
# Connectors — Notion (optional)
# ─────────────────────────────────────
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/api/connectors/notion/callback

# ─────────────────────────────────────
# Connectors — Slack (optional)
# ─────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/connectors/slack/callback

# ─────────────────────────────────────
# Connectors — GitHub (optional)
# ─────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/connectors/github/callback

# ─────────────────────────────────────
# LiveKit Video Calling (optional)
# ─────────────────────────────────────
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=
