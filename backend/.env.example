# Backend Config
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET=super_secret_jwt_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Config (PostgreSQL via SQLAlchemy)
DATABASE_URL=postgresql://projectgenai:sekret_password@postgres_db:5432/projectgenai
# Note: When running backend locally (outside docker), use:
# DATABASE_URL=postgresql://projectgenai:sekret_password@localhost:5432/projectgenai

# S3 Compatible Storage (MinIO local fallback)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
S3_ENDPOINT_URL=http://minio:9000
# Note: When running backend locally (outside docker), use:
# S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=knowledge-base

# Vector Store
CHROMA_PERSIST_DIR=/app/chroma_data
# LLM_MODEL=gpt-3.5-turbo
# EMBEDDING_MODEL=all-MiniLM-L6-v2
