# Backend Config
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET=super_secret_jwt_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Config (PostgreSQL via SQLAlchemy)
DATABASE_URL=
# Note: When running backend locally (outside docker), use:
# DATABASE_URL=

# S3 Compatible Storage (AWS or MinIOFallback)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=ap-south-1
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=nexus-knowledge-base-2026

# Document Encryption (AES-256 Envelope Encryption)
# Generate with: python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
DOCUMENT_ENCRYPTION_KEY=your_base64_32byte_master_key_here

# Vector Store
CHROMA_PERSIST_DIR=/app/chroma_data
# LLM_MODEL=gpt-3.5-turbo
# EMBEDDING_MODEL=all-MiniLM-L6-v2
